# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit your real keys.

# Base URL of the SkillLink Node.js backend (no trailing slash).
API_BASE_URL=https://skilllink-backend.lgufyp.app

# Google Maps SDK key restricted to Android package `com.example.skillink`
# and iOS bundle id in the Google Cloud Console. Enable the Geocoding API for
# the same key so labour signup can turn GPS into a street address.
GOOGLE_MAPS_API_KEY=your-google-maps-key-here

# Firebase Realtime Database URL (from Firebase Console → Project Settings).
FIREBASE_RTDB_URL=https://your-firebase-project.firebaseio.com
